        "jsCode": "\nfunction cleanText(text) {\n  if (!text) return '';\n  let cleaned = text.replace(/<[^>]*>/g, ' ');\n  cleaned = cleaned.replace(/\\s+/g, ' ').trim();\n  return cleaned;\n}\n\nconst crypto = require('crypto');\nfunction sha256(text) {\n  return crypto.createHash('sha256').update(text).digest('hex');\n}\n\nconst item = $input.item;\nconst subject = item.json.subject || '';\nconst textBody = item.json.text || '';\nconst messageId = item.json.messageId || item.json.message_id || '';\nconst conversationId = item.json.conversationId || item.json.conversation_id || '';\nconst fromEmail = item.json.from ? (item.json.from.value?.[0]?.address || item.json.from) : '';\nconst fromName = item.json.from?.value?.[0]?.name || '';\n\nconst cleanedBody = cleanText(textBody);\nconst bodyHash = sha256(cleanedBody);\nconst isThreadReply = /^(re|fwd|tr)\\s*:/i.test(subject.trim());\n\nreturn {\n  json: {\n    subject,\n    original_body: textBody,\n    cleaned_body: cleanedBody,\n    body_hash: bodyHash,\n    message_id: messageId,\n    conversation_id: conversationId,\n    from_email: fromEmail,\n    from_name: fromName,\n    is_thread_reply: isThreadReply\n  }\n};\n"
      },
