    {
      "parameters": {
        "operation": "executeQuery",
        "query": "(\n  SELECT gu.users_id AS glpi_assigned_id\n  FROM glpi_groups_users gu\n  JOIN glpi_groups g ON gu.groups_id = g.id\n  LEFT JOIN (\n    SELECT tu.users_id, COUNT(t.id) AS ticket_count, MIN(t.date_creation) AS oldest_ticket_date\n    FROM glpi_tickets_users tu\n    JOIN glpi_tickets t ON tu.tickets_id = t.id\n    WHERE tu.type = 2 AND t.status NOT IN (5, 6)\n    GROUP BY tu.users_id\n  ) workload ON gu.users_id = workload.users_id\n  WHERE g.name = $1\n  ORDER BY COALESCE(workload.ticket_count, 0) ASC, workload.oldest_ticket_date ASC\n  LIMIT 1\n)\nUNION ALL\nSELECT 2 AS glpi_assigned_id\nLIMIT 1;",
        "options": {
          "queryReplacement": "={{ $json.glpi_group_name }}"
        }
      },
