    {
      "parameters": {
        "jsCode": "// Priority 1: read ticket_id directly from structured subworkflow output\nlet ticketId = $json.ticket_id || null;\n\n// Priority 2: fallback regex on result text\nif (!ticketId) {\n  const resultText = $json.result || '';\n  const match = resultText.match(/(?:ticket|#|id\\s*[:=]\\s*)(\\d+)/i) || resultText.match(/(\\d{2,6})/);\n  ticketId = match ? parseInt(match[1], 10) : null;\n}\n\nif (!ticketId) {\n  return {\n    json: {\n      ticket_id: null,\n      success: false,\n      raw_result: $json.result || '',\n      error: 'Could not extract ticket_id from subworkflow output'\n    }\n  };\n}\n\nreturn {\n  json: {\n    ticket_id: ticketId,\n    success: true,\n    raw_result: $json.result || ''\n  }\n};"
      },
