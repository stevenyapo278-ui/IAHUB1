generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  TECHNICIAN
  REQUESTER
}

enum TicketStatus {
  NEW
  OPEN
  PENDING
  WAITING_FOR_USER
  SOLVED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum TicketEventType {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  EMAIL_RECEIVED
  EMAIL_SENT
  FOLLOWUP_ADDED
  AI_ANALYZED
  AI_DRAFT_GENERATED
  KNOWLEDGE_CREATED
  REOPENED
  ESCALATED
  REMINDER_SENT
  CLOSED_AUTO
  SPLIT_NEW_ISSUE
  CREATED_FROM_SPLIT
  AI_LOW_CONFIDENCE_CLOSE_SKIPPED
  AI_LOW_CONFIDENCE_REOPEN_SKIPPED
  AI_AUTO_REPLY_IGNORED
  AI_LIFETIME_EXCEEDED
  AI_SPLIT_LIMIT_REACHED
  NEEDS_HUMAN_REVIEW
  GLPI_SYNC_FAILED
  AI_CONVERSATION_ESCALATED
  AI_FOLLOWUP_DRAFT_GENERATED
}

enum TicketPriority {
  P1
  P2
  P3
  P4
}

enum TicketType {
  INCIDENT
  REQUEST
}

enum TicketUrgency {
  VERY_LOW
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
  MAJOR
}

enum TicketImpact {
  VERY_LOW
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
  MAJOR
}

enum ApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  fullName      String
  role          Role     @default(REQUESTER)
  team          Team?    @relation(fields: [teamId], references: [id])
  teamId        Int?
  isActive      Boolean  @default(true)
  glpiId        Int?     @unique // identifiant de l'utilisateur correspondant dans GLPI
  receiveDraftAlerts Boolean @default(false) // reçoit l'email de relance quand un AiEmailDraft attend trop longtemps une validation humaine (opt-in, activé par un admin)
  mustChangePassword Boolean @default(false) // force l'affichage de l'écran de changement de mot de passe à la prochaine connexion (ex: après réinitialisation par un admin)
  passwordResetTokens PasswordResetToken[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ticketsCreated  Ticket[] @relation("TicketRequester")
  ticketsAssigned Ticket[] @relation("TicketAssignee")
  ticketsApproved Ticket[] @relation("TicketApprover")
  ticketsObserved Ticket[] @relation("TicketObservers")
  followups       Followup[]
  aiEmailDraftsReviewed AiEmailDraft[]
  knowledgeDraftsReviewed KnowledgeDraft[]
  skills          UserSkill[]
  permissionGroups PermissionGroup[] @relation("UserPermissionGroups")
}

model PermissionGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  permissions String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members User[] @relation("UserPermissionGroups")
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  category  String?
  glpiGroupId Int?   @unique // identifiant du groupe correspondant dans GLPI
  groupEmail  String? // adresse email de groupe (ex: reseau@entreprise.com), destinataire du récapitulatif quotidien des tickets de cette équipe
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members User[]
  tickets Ticket[]
}

// Catégories de tickets synchronisées depuis les ITILCategory de GLPI — évite de coder en
// dur la correspondance nom <-> itilcategories_id (cf. glpiMapping.js, risque de désynchro
// si la liste des catégories change côté GLPI).
model TicketCategory {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  glpiCategoryId  Int      @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Ticket {
  id            Int            @id @default(autoincrement())
  title         String
  content       String
  status        TicketStatus   @default(NEW)
  priority      TicketPriority @default(P3)
  category      String?
  glpiTicketId  Int?     @unique // identifiant du ticket correspondant dans GLPI, une fois synchronisé
  aiProcessed   Boolean  @default(false) // vrai si le ticket a été créé/traité par l'agent IA de triage (workflow n8n)

  sourceEmail   String? // adresse email de l'expéditeur du mail ayant déclenché la création du ticket (via n8n)
  sourceName    String? // nom affiché de l'expéditeur du mail d'origine
  sourceSubject String? // sujet du mail d'origine

  requester     User?  @relation("TicketRequester", fields: [requesterId], references: [id])
  requesterId   Int?

  assignedTo    User?  @relation("TicketAssignee", fields: [assignedToId], references: [id])
  assignedToId  Int?

  team          Team?  @relation(fields: [teamId], references: [id])
  teamId        Int?

  approvalStatus ApprovalStatus @default(NOT_REQUIRED)
  approvedBy     User?    @relation("TicketApprover", fields: [approvedById], references: [id])
  approvedById   Int?
  approvedAt     DateTime?
  approvalNote   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  solvedAt      DateTime?
  closedAt      DateTime?

  // Identifiants de conversation Outlook pour le rattachement automatique
  outlookConversationId String?
  lastUserReplyAt       DateTime?
  reminderSentAt        DateTime?
  reminderCount         Int       @default(0)
  aiSummary             String?
  contentEmbedding      Unsupported("vector(1024)")?

  // Garde-fous sur l'analyse d'intention automatique des réponses email
  splitCount            Int       @default(0) // nombre de tickets déjà créés par scission depuis ce ticket
  firstOpenedAt         DateTime? // date du tout premier passage à OPEN, pour plafonner la durée de vie totale
  aiExchangeCount       Int       @default(0) // nombre de réponses de suivi déjà générées par l'IA sur la conversation en cours, remis à 0 à la résolution — au-delà du seuil (followupEscalation.js), on escalade systématiquement vers un humain

  // Incident majeur — regroupement multi-sites
  isMajorIncident Boolean  @default(false)
  impactedSites   String[] @default([])
  firstDetectedAt DateTime?
  lastDetectedAt  DateTime?

  // Champs alignés sur le formulaire de ticket GLPI
  type        TicketType   @default(INCIDENT)
  source      String?      // "Helpdesk", "Email", "Téléphone", etc.
  urgency     TicketUrgency  @default(MEDIUM)
  impact      TicketImpact   @default(MEDIUM)
  externalId  String?      // "ID externe" GLPI
  observers   User[]       @relation("TicketObservers")

  followups       Followup[]
  aiEmailDrafts   AiEmailDraft[]
  attachments     TicketAttachment[]
  aiSuggestions   AiTicketSuggestion[]
  knowledgeDrafts KnowledgeDraft[]
  messages        TicketMessage[]
  events          TicketEvent[]
}

// Suggestion d'action interne générée par l'agent IA pour le technicien (ex: réassigner, changer priorité, ticket similaire)
model AiTicketSuggestion {
  id          Int      @id @default(autoincrement())
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    Int
  suggestion  String   // texte de la suggestion ("Augmenter la priorité à P1", "Ticket similaire #42", ...)
  reason      String?  // justification donnée par l'IA
  createdAt   DateTime @default(now())
}

// Pièce jointe d'un ticket, importée depuis GLPI (Document_Item) lors de la synchronisation
enum EmailAttachmentSource {
  MANUAL_UPLOAD
  INCOMING_EMAIL
}

model TicketAttachment {
  id              Int                   @id @default(autoincrement())
  ticket          Ticket                @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId        Int
  glpiDocumentId  Int                   @unique
  filename        String
  mimeType        String?
  source          EmailAttachmentSource @default(MANUAL_UPLOAD)
  incomingEmail   IncomingEmail?        @relation(fields: [incomingEmailId], references: [id], onDelete: SetNull)
  incomingEmailId Int?
  contentHash     String? // hash sha256 du contenu binaire, pour détecter les logos/signatures dupliqués entre messages d'un même ticket
  createdAt       DateTime              @default(now())
}

model Followup {
  id        Int      @id @default(autoincrement())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId  Int
  author    User?    @relation(fields: [authorId], references: [id])
  authorId  Int?
  content   String
  createdAt DateTime @default(now())
}

model ApiConfig {
  id          Int      @id @default(autoincrement())
  serviceName String   @unique
  baseUrl     String?
  apiKey      String?
  extra       Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Réglages globaux d'automatisation IA, modifiables depuis Paramètres > Automatisation.
// Table singleton : une seule ligne, toujours id=1.
model SystemSettings {
  id                     Int      @id @default(1)
  autoApproveGlpiSolutions Boolean @default(false) // approuve automatiquement la validation de solution GLPI dès qu'un ticket passe Résolu
  autoSendAiEmails       Boolean  @default(false) // envoie directement les emails générés par l'IA sans passer par le circuit d'approbation humaine AiEmailDraft
  enableFewShotTriage    Boolean  @default(true)  // active l'apprentissage Few-Shot par historique pour la classification de tickets

  // URLs absolues du serveur, utilisées pour générer des liens/ressources dans les emails sortants
  // (logo de signature, lien d'approbation de brouillon, lien de réinitialisation de mot de passe).
  // Configurables ici plutôt que seulement via BACKEND_URL/FRONTEND_URL (variables d'environnement
  // Docker) pour permettre de pointer vers l'IP réseau réelle du serveur sans rebuild — utile dès
  // que le serveur est accédé autrement qu'en localhost. Laisser vide = retombe sur la variable
  // d'environnement, puis sur localhost en dernier recours.
  backendUrl  String? @db.Text
  frontendUrl String? @db.Text
  // Fréquences de synchronisation automatique (Paramètres > Automatisation > Fréquences de synchronisation).
  // Toutes désactivables individuellement en mettant 0 — le bouton manuel correspondant (s'il existe) reste alors le seul moyen de forcer une synchro.
  glpiTicketsSyncIntervalSeconds         Int @default(20)   // tickets GLPI + pièces jointes + approbations auto
  emailSyncIntervalSeconds               Int @default(15)   // relevé des boîtes mail entrantes
  glpiTeamsCategoriesSyncIntervalMinutes Int @default(10)   // groupes GLPI -> équipes, ITILCategory -> catégories
  aiModelsSyncIntervalHours              Int @default(24)   // liste des modèles disponibles par fournisseur IA

  // Relance des brouillons AiEmailDraft non validés (Paramètres > Automatisation).
  draftReminderEnabled      Boolean @default(true)
  draftReminderDelayMinutes Int     @default(30) // délai après lequel une relance est envoyée si le brouillon est toujours PENDING

  // Texte de l'accusé de réception automatique (Paramètres > Automatisation > Emails).
  // Placeholders disponibles : {ticketId}, {subject}, {toName}. Laisser vide = texte par défaut codé en dur.
  acknowledgementMessage String? @db.Text

  // Notifier le technicien par email quand un ticket lui est automatiquement assigné
  // (Paramètres > Automatisation > Notifications internes).
  notifyTechnicianOnAssignment Boolean @default(false)

  // Signature HTML insérée en bas de tous les emails automatiques (accusé de réception, relance,
  // notification d'incident connu), à la place du "Cordialement, Support IT" codé en dur. Laisser vide = défaut.
  emailSignature String? @db.Text
  // URL absolue du logo uploadé (Paramètres > Automatisation), insérée automatiquement dans emailSignature.
  signatureLogoUrl    String? @db.Text
  signatureLogoHeight Int     @default(60) // hauteur d'affichage du logo dans l'email, en pixels

  // Récapitulatif quotidien des tickets ouverts (Paramètres > Automatisation > Récapitulatif quotidien).
  dailySummaryEnabled   Boolean  @default(false)
  dailySummaryTime      String   @default("18:00") // heure locale au format "HH:mm", vérifiée chaque minute par dailySummaryScheduler
  dailySummaryRecipients String[] @default([])      // liste libre d'adresses email, indépendante des comptes ERP
  dailySummaryLastSentDate String? // date "YYYY-MM-DD" du dernier envoi, pour ne déclencher qu'une fois par jour

  updatedAt              DateTime @updatedAt
}

// Suivi de santé de chaque tâche automatique planifiée (sync GLPI, pipeline email, relances...) —
// permet de détecter et d'alerter en cas de panne silencieuse prolongée, au lieu de ne laisser
// la trace que dans les logs serveur que personne ne consulte en routine.
model SchedulerHealth {
  id                    Int      @id @default(autoincrement())
  name                  String   @unique // identifiant technique de la tâche, ex: "tickets GLPI"
  consecutiveFailures   Int      @default(0)
  lastError             String?  @db.Text
  lastFailureAt         DateTime?
  lastSuccessAt         DateTime?
  alertSentAt           DateTime? // dernière fois qu'une alerte a été envoyée pour cette série d'échecs — évite de spammer à chaque cycle tant que la panne persiste
  updatedAt             DateTime @updatedAt
}

// Fournisseur d'IA (OpenAI, Anthropic, Google Gemini, NVIDIA, Mistral, etc.)
model AiProvider {
  id          Int      @id @default(autoincrement())
  name        String   @unique // identifiant technique : "openai", "anthropic", "gemini", "nvidia", ...
  label       String   // nom affiché : "OpenAI", "Anthropic (Claude)", ...
  baseUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  models AiModel[]
  keys   AiKey[]
}

// Modèle disponible chez un fournisseur (gpt-4o, claude-sonnet-4-6, gemini-1.5-pro, ...)
enum AiModelType {
  CHAT
  EMBEDDING
  RERANK
}

model AiModel {
  id         Int        @id @default(autoincrement())
  provider   AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId Int
  name       String     // identifiant technique du modèle
  label      String?    // nom affiché
  type       AiModelType @default(CHAT) // détermine si ce modèle peut être "par défaut" pour le chat (5 prompts IA) ou pour les embeddings (base de connaissances) — un fournisseur peut avoir un défaut distinct pour chaque type
  isDefault  Boolean    @default(false)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  keys AiKey[]

  @@unique([providerId, name])
}

// Clé API pour un fournisseur, optionnellement liée à un modèle précis.
// Plusieurs clés possibles pour le même fournisseur/modèle (rotation, quotas, comptes différents).
model AiKey {
  id         Int        @id @default(autoincrement())
  provider   AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId Int
  model      AiModel?   @relation(fields: [modelId], references: [id], onDelete: SetNull)
  modelId    Int?
  label      String     // nom donné par l'utilisateur : "Clé perso", "Clé société", ...
  apiKey     String
  isActive   Boolean    @default(true)
  isDefault  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum EmailProvider {
  OUTLOOK
  GMAIL
  IMAP_SMTP
}

// Configuration de boîte mail (ex: Outlook/Microsoft 365) utilisée par le workflow ITSM
model EmailAccount {
  id            Int           @id @default(autoincrement())
  label         String        // nom donné par l'utilisateur : "Support IT", "Boîte principale", ...
  provider      EmailProvider @default(OUTLOOK)
  emailAddress  String

  // OAuth2 (Outlook / Gmail)
  clientId      String?
  clientSecret  String?
  tenantId      String?
  refreshToken  String?

  // IMAP/SMTP générique
  imapHost      String?
  imapPort      Int?
  smtpHost      String?
  smtpPort      Int?
  username      String?
  password      String?
  useTls        Boolean       @default(true)

  isActive      Boolean       @default(true)
  isDefault     Boolean       @default(false)

  // Suivi du polling Microsoft Graph
  lastSyncAt    DateTime?
  deltaLink     String?       // lien de pagination delta Microsoft Graph pour ne traiter que les nouveaux messages

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

// Email entrant reçu via Microsoft Graph, traité par le pipeline IA
model IncomingEmail {
  id                  Int           @id @default(autoincrement())
  graphMessageId      String        @unique
  internetMessageId   String?
  conversationId      String?
  inReplyTo           String?
  references          String?
  emailAccountId      Int
  fromEmail           String
  fromName            String?
  subject             String
  bodyPreview         String?
  bodyHtml            String?
  receivedAt          DateTime

  // Résultat de l'analyse IA
  aiSummary           String?
  aiCategory          String?
  aiPriority          String?
  aiTeam              String?
  aiConfidence        Float?
  aiIsSpam            Boolean       @default(false)
  aiIntent            String?       // RESOLVED | STILL_PRESENT | NEW_INFO | QUESTION | REOPEN

  // Ticket rattaché
  glpiTicketId        Int?
  erpTicketId         Int?
  isNewTicket         Boolean       @default(true)

  status              String        @default("PENDING")
  error               String?

  ccRecipients        String[]      @default([])
  hasAttachments      Boolean       @default(false)
  attachments         TicketAttachment[]

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([conversationId])
  @@index([internetMessageId])
}

// Historique complet des messages entrants et sortants d'un ticket
model TicketMessage {
  id                Int              @id @default(autoincrement())
  ticket            Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId          Int
  direction         MessageDirection
  sender            String
  recipients        String[]
  subject           String
  body              String
  bodyHtml          String?

  // Identifiants Outlook pour le threading
  outlookMessageId  String?          @unique
  internetMessageId String?
  inReplyTo         String?
  conversationId    String?

  ccRecipients      String[]         @default([])
  timestamp         DateTime         @default(now())
  createdAt         DateTime         @default(now())

  @@index([ticketId])
  @@index([conversationId])
}

// Journal d'audit de toutes les actions sur un ticket
model TicketEvent {
  id          Int             @id @default(autoincrement())
  ticket      Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId    Int
  type        TicketEventType
  actor       String          @default("SYSTEM") // email utilisateur ou "SYSTEM" / "AI"
  payload     Json?           // données contextuelles de l'événement
  createdAt   DateTime        @default(now())

  @@index([ticketId])
}

// Configuration des relances automatiques (délais en jours)
model ReminderConfig {
  id                Int      @id @default(autoincrement())
  firstReminderDays Int      @default(2)
  secondReminderDays Int     @default(5)
  preCloseDays      Int      @default(10)
  autoCloseDays     Int      @default(15)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Brouillon de réponse email généré par l'agent IA (workflow n8n), en attente de validation humaine
model AiEmailDraft {
  id              Int            @id @default(autoincrement())
  ticket          Ticket?        @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  ticketId        Int?

  glpiTicketId    Int?
  recipientEmail  String
  ccRecipients    String[]       @default([])
  subject         String
  proposedContent String

  draftKind       String         @default("ACKNOWLEDGEMENT") // ACKNOWLEDGEMENT | KNOWN_INCIDENT | CONVERSATION_FOLLOWUP
  exchangeTurn    Int? // numéro du tour de conversation (copie de Ticket.aiExchangeCount), uniquement pour CONVERSATION_FOLLOWUP

  // Id Outlook du message reçu auquel cette réponse fait suite (TicketMessage.outlookMessageId) —
  // utilisé à l'envoi (emailSender.sendEmail) pour répondre dans le même fil de conversation côté
  // destinataire au lieu de créer un nouvel email visuellement déconnecté. Vide pour les brouillons
  // qui ne répondent à aucun message précis (ex: accusé de réception initial).
  inReplyToGraphMessageId String?
  outlookConversationId   String?

  status          ApprovalStatus @default(PENDING)
  reviewedBy      User?          @relation(fields: [reviewedById], references: [id])
  reviewedById    Int?
  reviewedAt      DateTime?
  reviewNote      String?

  sentAt          DateTime?

  reminderCount   Int       @default(0) // nombre de relances déjà envoyées pour ce brouillon en attente
  lastReminderAt  DateTime? // date de la dernière relance envoyée — évite de relancer à chaque cycle

  approvalTokens  EmailApprovalToken[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// Lien d'approbation à distance envoyé par email de relance, pour qu'un responsable hors du
// réseau local (pas connecté à l'app) puisse approuver/rejeter/modifier un AiEmailDraft sans
// login. Token opaque à usage unique, distinct d'un JWT : invalidé dès qu'il est consommé
// (approve/reject) et expire après un délai court, pour limiter l'exposition si le lien fuit.
model EmailApprovalToken {
  id          Int           @id @default(autoincrement())
  token       String        @unique
  draft       AiEmailDraft  @relation(fields: [draftId], references: [id], onDelete: Cascade)
  draftId     Int
  expiresAt   DateTime
  usedAt      DateTime?
  // internetMessageId de l'email de relance envoyé contenant ce token — permet de reconnaître
  // la RÉPONSE du responsable (in-reply-to) quand il préfère répondre directement par email
  // ("j'approuve" / "je rejette") plutôt que de cliquer le lien, notamment hors réseau local
  // sans accès au tunnel/VPN exposant l'application.
  reminderInternetMessageId String? @unique
  createdAt   DateTime      @default(now())
}

// ── Compétences métier des techniciens ─────────────────────────────────────
// Une compétence est un domaine d'expertise ("Réseau", "VPN", "Active Directory", "Linux", etc.)
// qui peut être assigné à un technicien avec un niveau de maîtrise (1-5).
// Utilisé par ticketAutoAssign.js pour l'assignation intelligente des tickets.
model Skill {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  category    String?     // Catégorie parente pour regrouper les compétences (ex: "Infrastructure")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userSkills  UserSkill[]
}

// Niveau de compétence d'un technicien pour un domaine donné
model UserSkill {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId   Int
  level     Int      @default(3) // 1 = débutant, 5 = expert
  createdAt DateTime @default(now())

  @@unique([userId, skillId])
}

// Journal des réassignations de tickets — utilisé par le système d'auto-apprentissage
// pour mesurer la précision des assignations automatiques et améliorer les futures suggestions.
model ReassignmentLog {
  id                    Int      @id @default(autoincrement())
  ticketId              Int      // ticket concerné
  previousTechnicianId  Int?     // technicien avant réassignation (null = non assigné)
  newTechnicianId       Int?     // nouveau technicien (null = désassigné)
  reason                String?  // raison donnée par l'humain : "surcharge", "compétence", "disponibilité", "autre"
  wasAutoAssigned       Boolean  @default(false) // true si le ticket avait été assigné automatiquement
  assignedByUserId      Int?     // utilisateur qui a fait la réassignation
  createdAt             DateTime @default(now())
}

// ── Notifications temps réel ────────────────────────────────────────────
// Notification persistante affichée dans le volet de notification de la navbar,
// créée automatiquement lors des événements socket (ticket créé, assigné, mis à jour).
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      // destinataire de la notification
  type      String   // "ticket_created" | "ticket_assigned" | "ticket_updated"
  title     String   // titre court affiché dans le volet
  message   String   // message détaillé
  link      String?  // lien de navigation (ex: "/tickets/42")
  metadata  Json?    // données supplémentaires (priorité, méthode d'assignation, etc.)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// Lien "mot de passe oublié" envoyé par email à l'utilisateur — token opaque à usage unique,
// expire après un délai court, comme EmailApprovalToken mais volontairement séparé : ce token
// donne accès à la définition d'un mot de passe de connexion complet, un niveau de sensibilité
// différent d'approuver un brouillon d'email.
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

enum KnowledgeDocumentStatus {
  PROCESSING
  READY
  ERROR
}

// Document source de la base de connaissances (PDF, DOCX, Markdown, ou article approuvé)
model KnowledgeDocument {
  id          Int                     @id @default(autoincrement())
  title       String
  sourceType  String                  // "pdf" | "docx" | "markdown" | "article"
  filename    String?
  status      KnowledgeDocumentStatus @default(PROCESSING)
  error       String?
  category    String?                 // Catégorie du document (ex: "Réseau", "Logiciel", "Matériel")
  tags        String[]                // Tags pour filtrage
  author      String?                 // Auteur du document
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  chunks      KnowledgeChunk[]
  feedbacks   KnowledgeFeedback[]
}

// Fragment de texte d'un document, avec son embedding pour la recherche de similarité (pgvector)
model KnowledgeChunk {
  id          Int               @id @default(autoincrement())
  document    KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId  Int
  chunkIndex  Int
  content     String
  embedding   Unsupported("vector(1024)")?
  createdAt   DateTime          @default(now())

  @@index([documentId])
}

// Feedback sur un résultat de recherche de la base de connaissances
enum KnowledgeFeedbackRating {
  NOT_RELEVANT
  SOMEWHAT_RELEVANT
  VERY_RELEVANT
}

model KnowledgeFeedback {
  id         Int                      @id @default(autoincrement())
  document   KnowledgeDocument        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId Int
  chunkId    Int?                     // ID du chunk spécifique si applicable
  query      String                   // La requête de recherche qui a généré ce résultat
  rating     KnowledgeFeedbackRating  // Note de pertinence
  comment    String?                  // Commentaire optionnel
  userEmail  String?                  // Email de l'utilisateur qui a donné le feedback
  createdAt  DateTime                 @default(now())
}

enum KnowledgeDraftStatus {
  PENDING
  APPROVED
  REJECTED
}

// Brouillon d'article de connaissance généré par l'IA à partir d'un ticket résolu
model KnowledgeDraft {
  id          Int                  @id @default(autoincrement())
  ticket      Ticket?              @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  ticketId    Int?

  title       String
  problem     String
  cause       String
  solution    String
  keywords    String[]
  category    String?              // Catégorie proposée pour l'article
  tags        String[]             // Tags proposés pour l'article

  status      KnowledgeDraftStatus @default(PENDING)
  reviewedBy  User?                @relation(fields: [reviewedById], references: [id])
  reviewedById Int?
  reviewedAt  DateTime?
  reviewNote  String?

  documentId  Int? // document de connaissance créé une fois approuvé

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

// Prompt IA modifiable depuis Paramètres > Prompts IA. key = identifiant technique fixe (un par
// usage : analyzeEmail, analyzeIntent, stripSignature, filterOutSignatureImages, generateKnowledgeDraft).
// template contient des espaces réservés {{nomVariable}} substitués au moment de l'appel — si la ligne
// n'existe pas encore en base, le code retombe sur un texte par défaut codé en dur (jamais de crash).
model PromptTemplate {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  template  String
  updatedAt DateTime @updatedAt
}

// Workflow n8n déclenchable depuis l'UI (ex: synchro GLPI, notification, automatisation)
model N8nWorkflow {
  id          Int      @id @default(autoincrement())
  name        String   // nom affiché : "Synchro GLPI", "Notification Slack", ...
  webhookUrl  String   // URL du webhook n8n à appeler
  description String?
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  lastStatus  String?  // "success" | "error"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Mapping entre emails (Outlook) et tickets (GLPI/ERP) — pour le workflow ITSM
model TicketMapping {
  id               Int      @id @default(autoincrement())
  provider         String   // "outlook", "gmail", etc.
  conversationId   String?  @db.Text
  messageId        String?  @db.Text
  requesterEmail   String?
  ticketId         Int?     // ID du ticket dans le système (GLPI ou ERP)
  status           String?  // "open", "solved", "closed"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([conversationId])
  @@index([messageId])
}

// Historique des événements de mail pour le workflow ITSM
model MailEvent {
  id               Int      @id @default(autoincrement())
  messageId        String   @db.Text
  conversationId   String?  @db.Text
  fromEmail        String
  subject          String
  bodyHash         String
  decision         Json
  relatedTicketId  Int?
  createdAt        DateTime @default(now())

  @@index([messageId])
  @@index([conversationId])
}

// File d'attente des erreurs de workflow ITSM
model MailError {
  id                     Int       @id @default(autoincrement())
  messageId              String    @db.Text
  conversationId         String?   @db.Text
  fromEmail              String
  subject                String
  bodyHash               String
  errorStage             String
  errorDetails           String?   @db.Text
  rawSubworkflowOutput   String?   @db.Text
  failedAt               DateTime  @default(now())
  createdAt              DateTime  @default(now())

  @@index([messageId])
  @@index([conversationId])
}

// Équipes support pour le mapping entre l'IA et GLPI
model SupportTeam {
  id               Int       @id @default(autoincrement())
  teamName         String    @unique
  glpiGroupName    String?   // Nom du groupe correspondant dans GLPI
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Index de similarité sémantique des tickets (pour la détection de doublons dans le workflow)
model TicketSimilarityIndex {
  id               Int                     @id @default(autoincrement())
  ticketId         Int
  summary          String
  bodyShort        String
  content          String
  embedding        Unsupported("vector(1024)")?
  status           String
  requesterEmail   String
  metadata         Json?
  openedAt         DateTime                @default(now())
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([ticketId])
  @@index([requesterEmail])
}

// Règles de triage automatique déterminant l'assignation des tickets sans appeler l'IA
model TriageRule {
  id             Int      @id @default(autoincrement())
  isActive       Boolean  @default(true)
  priority       Int      @default(0)   // plus élevé = évalué en premier
  matchField     String   // 'subject' | 'body' | 'subject_or_body' | 'from'
  matchType      String   // 'contains' | 'regex' | 'equals' | 'starts_with'
  matchValue     String   // valeur à chercher (insensible à la casse)
  category       String?  // catégorie ITSM assignée (ex: "Matériel", "VPN", etc.)
  skillName      String?  // compétence cible (ex: "PORT USB")
  teamName       String?  // équipe cible (ex: "Sécurité")
  ticketPriority String?  // P1|P2|P3|P4
  isSpam         Boolean  @default(false)
  label          String   // Description humaine de la règle
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

