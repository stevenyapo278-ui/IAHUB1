# =============================================================================
# IA Hub — Helpdesk ITSM Automation
# Copiez ce fichier vers .env et remplissez les valeurs requises
# =============================================================================

# ── Base de données PostgreSQL ─────────────────────────────────────────────
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/erp_itsm?schema=public

# ── Authentification JWT ───────────────────────────────────────────────────
JWT_SECRET=mon_secret_jwt_tres_long_et_aleatoire
JWT_EXPIRES_IN=8h

# ── URLs du service ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:4000
BACKEND_URL=http://localhost:4000
CORS_ORIGIN=*
PORT=4000

# ── GLPI (ITSM) ────────────────────────────────────────────────────────────
# Configuré via l'interface Paramètres > Autres intégrations
GLPI_URL=
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=

# ── Microsoft / Outlook (OAuth2) ───────────────────────────────────────────
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/oauth/outlook/callback

# ── n8n Workflow Automation ────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=debug            # debug | info | warn | error
LOG_DIR=logs               # Dossier des fichiers de log (relatif au backend)

# ── Mode développement ─────────────────────────────────────────────────────
# VITE_API_URL est utilisé par le frontend uniquement
VITE_API_URL=http://localhost:4000/api
