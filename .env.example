# =============================================================================
# IA Hub — Helpdesk ITSM Automation
# Copiez ce fichier vers .env et remplissez les valeurs requises
# =============================================================================

# ── Base de données PostgreSQL ─────────────────────────────────────────────
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/erp_itsm?schema=public

# ── Authentification JWT ───────────────────────────────────────────────────
JWT_SECRET=mon_secret_jwt_tres_long_et_aleatoire
JWT_EXPIRES_IN=8h

# ── URLs du service ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:4000
BACKEND_URL=http://localhost:4000
CORS_ORIGIN=*
PORT=4000

# ── GLPI (ITSM) ────────────────────────────────────────────────────────────
# Configuré via l'interface Paramètres > Autres intégrations
GLPI_URL=http://glpi/apirest.php
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=

# ── Microsoft / Outlook OAuth ──────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/oauth/outlook/callback

# ── Fournisseurs IA ────────────────────────────────────────────────────────
# Configuré via l'interface Paramètres > IA

# ── Logs ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=erp-backend/logs

# ── n8n (optionnel) ────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=
N8N_WEBHOOK_URL=

# ── Paramètres avancés (ne pas modifier sans comprendre) ───────────────────
NODE_ENV=${NODE_ENV:-production}

# ── Configuration de la base GLPI locale (Docker Compose optionnel) ────────
GLPI_DB_HOST=db
GLPI_DB_PORT=3306
GLPI_DB_NAME=glpi
GLPI_DB_USER=glpi
GLPI_DB_PASSWORD=glpi
