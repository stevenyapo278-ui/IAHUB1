# JWT
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars

# Microsoft OAuth (optionnel - pour connexion Outlook)
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/oauth/outlook/callback

# URL API pour le frontend (mettre l'IP du serveur en production)
VITE_API_URL=http://localhost:4000/api

# URL publique du frontend (mettre l'IP/domaine du serveur en production) — utilisée par le
# backend pour générer les liens d'approbation à distance dans les emails de relance.
FRONTEND_URL=http://localhost:3000

# URL publique du backend (mettre l'IP/domaine du serveur en production) — utilisée pour générer
# l'URL du logo de signature email, qui doit être accessible depuis la boîte mail du destinataire.
BACKEND_URL=http://localhost:4000

# GLPI : ne se configure pas ici. Va dans Settings -> Autres intégrations une fois
# l'application démarrée (voir README, section "GLPI — nouveau ou existant").
